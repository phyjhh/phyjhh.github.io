---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type PostEntry = CollectionEntry<"blog"> | CollectionEntry<"notes"> | CollectionEntry<"publications">;

type Props = {
  variant?: "h2" | "h3";
} & PostEntry;

const { variant: Heading = "h2", id, data, filePath, collection } = Astro.props;

const { title, description, ...props } = data;

// 根据集合类型确定基础路径
const basePath = collection === "blog" ? "/posts" : 
                 collection === "notes" ? "/notes" : 
                 collection === "publications" ? "/publications" : "/posts";
---

<li class="my-6">
  <a
    href={getPath(id, filePath, true, basePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading style={{ viewTransitionName: slugifyStr(title) }}>
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  <p>{description}</p>
</li>
